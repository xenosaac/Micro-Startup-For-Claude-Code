# Absolute path to the repo this triad should operate on.
TARGET_REPO="/absolute/path/to/your/repo"

# Claude CLI binary.
CLAUDE_BIN="${HOME}/.local/bin/claude"

# Git branch used by the Engineer role.
ENGINEER_BRANCH="codex/micro-startup"

# Repo-relative working documents inside the target repo.
WORKING_LOG_REL="docs/working_log.md"
PRODUCT_DOC_REL="docs/product_lead.md"
DESIGN_DOC_REL="docs/design_lead.md"

# Tmux session name.
SESSION_NAME="micro-startup"

# Model selection.
CLAUDE_MODEL="opus"
